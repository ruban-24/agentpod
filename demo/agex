#!/bin/bash
# Fake agex CLI for VHS demo recording.
# Produces pre-baked ANSI output so the GIF is deterministic and pixel-perfect.

set -e

# ANSI codes
G='\033[32m'   # green
R='\033[31m'   # red
B='\033[34m'   # blue
Y='\033[33m'   # yellow
D='\033[2m'    # dim
BD='\033[1m'   # bold
RST='\033[0m'  # reset

args="$*"

case "$args" in
  *"create"*"JWT"*|*"create"*"jwt"*)
    echo ""
    echo -e "${G}┃${RST} ${G}✓${RST} Created task ${BD}${B}a1b2c3${RST}"
    echo -e "${G}┃${RST} JWT auth"
    echo -e "${G}┃${RST} ${D}branch: agex/a1b2c3${RST}"
    echo ""
    ;;

  *"create"*"session"*|*"create"*"Session"*)
    echo ""
    echo -e "${G}┃${RST} ${G}✓${RST} Created task ${BD}${B}d4e5f6${RST}"
    echo -e "${G}┃${RST} Redis sessions"
    echo -e "${G}┃${RST} ${D}branch: agex/d4e5f6${RST}"
    echo ""
    ;;

  *"create"*"token"*)
    echo ""
    echo -e "${G}┃${RST} ${G}✓${RST} Created task ${BD}${B}g7h8i9${RST}"
    echo -e "${G}┃${RST} Fix token race"
    echo -e "${G}┃${RST} ${D}branch: agex/g7h8i9${RST}"
    echo ""
    ;;

  *"summary"*)
    echo ""
    echo -e "${BD}agex · 2 tasks${RST}"
    echo -e "2 tasks · ${G}1 completed${RST} · ${Y}1 running${RST}"
    echo ""
    echo -e "${G}┃${RST} ${G}✓${RST} ${B}a1b2c3${RST}  ${G}completed${RST}  ${D}12.4s${RST}  ${G}3/3${RST}  ${D}+47 -12${RST}  JWT auth"
    echo -e "${Y}┃${RST} ${Y}▶${RST} ${B}d4e5f6${RST}  ${Y}running${RST}    ${D} 8.1s${RST}               Redis sessions"
    echo ""
    ;;

  *"verify"*)
    echo ""
    echo -e "${B}a1b2c3${RST} · verification"
    echo ""
    echo -e "${G}✓${RST} npm test          ${D}(4.2s)${RST}"
    echo -e "${G}✓${RST} npm run lint      ${D}(2.1s)${RST}"
    echo -e "${G}✓${RST} npm run build     ${D}(6.1s)${RST}"
    echo ""
    echo -e "${G}${BD}All 3 checks passed${RST} ${D}(12.4s total)${RST}"
    echo ""
    ;;

  *"review"*)
    echo ""
    echo -e "${B}a1b2c3${RST} · JWT auth · ${D}+47 -12 · 4 files${RST}"
    echo ""
    echo -e "${D}COMMITS${RST}"
    echo -e "  ${D}a1b2c3d${RST}  refactor: extract auth middleware"
    echo -e "  ${D}d4e5f6a${RST}  feat: add JWT token generation"
    echo -e "  ${D}b7c8d9e${RST}  test: add auth middleware tests"
    echo ""
    echo -e "${D}FILES${RST}"
    echo -e "  ${Y}M${RST} src/auth/middleware.ts  ${G}+18${RST} ${R}-4${RST}"
    echo -e "  ${Y}M${RST} src/auth/token.ts       ${G}+12${RST} ${R}-2${RST}"
    echo -e "  ${G}A${RST} src/auth/jwt.ts         ${G}+15${RST}"
    echo -e "  ${Y}M${RST} tests/auth.test.ts       ${G}+2${RST} ${R}-6${RST}"
    echo ""
    ;;

  *"compare"*)
    echo ""
    echo -e "  ID       Status      Checks  Changes  Duration  Prompt"
    echo -e "  ────────────────────────────────────────────────────────────"
    echo -e "  ${B}a1b2c3${RST}   ${G}completed${RST}   ${G}3/3${RST}   ${D}+47 -12${RST}  ${D}12.4s${RST}     JWT auth"
    echo -e "  ${B}d4e5f6${RST}   ${G}completed${RST}   ${G}3/3${RST}   ${D}+31 -8${RST}   ${D} 9.2s${RST}     Redis sessions"
    echo -e "  ${B}g7h8i9${RST}   ${R}failed${RST}      ${R}1/3${RST}   ${D}+93 -41${RST}  ${D}15.2s${RST}     Fix token race"
    echo -e "  ────────────────────────────────────────────────────────────"
    echo -e "  3 tasks · ${G}2 completed${RST} · ${R}1 failed${RST}"
    echo ""
    ;;

  *"accept"*)
    echo ""
    echo -e "${G}┃${RST} ${G}✓${RST} Accepted ${BD}${B}a1b2c3${RST} into main"
    echo -e "${G}┃${RST} ${D}strategy: fast-forward · commit: e9f2a17${RST}"
    echo ""
    ;;

  *)
    echo "fake-agex: unknown command: $args" >&2
    exit 1
    ;;
esac
